dataset/
*.dcm
*.npy
*.npz

# Outputs
outputs/
checkpoints/
figures/
results/
predictions/

# Logs (folder preserved as empty placeholder)
logs/*
!logs/.gitkeep

# Report: only the output figures are tracked. The LaTeX source, compiled PDF,
# and figure-generation script are kept local only.
report/*
!report/figures/
!report/figures/**
!report/legacy/
report/legacy/*
!report/legacy/.gitkeep

